#!/usr/bin/env bash
# ~/.local/bin/battery-notify

BATTERY_PATH="/sys/class/power_supply/BAT1"
CAPACITY=$(cat "$BATTERY_PATH/capacity")
STATUS=$(cat "$BATTERY_PATH/status")  # Charging / Discharging / Full

STATE_FILE="/tmp/battery-notify-last"
LAST=$(cat "$STATE_FILE" 2>/dev/null || echo "")

if [[ "$STATUS" == "Discharging" ]]; then
    if (( CAPACITY <= 5 )) && [[ "$LAST" != "empty" ]]; then
        notify-send -u critical "Battery Empty" "${CAPACITY}% remaining"
        echo "empty" > "$STATE_FILE"
      elif (( CAPACITY > 5 )) && (( CAPACITY <= 15 )) && [[ "$LAST" != "critical" ]]; then
        notify-send -u critical "Battery Critical" "${CAPACITY}% remaining"
        echo "critical" > "$STATE_FILE"
      elif (( CAPACITY > 15 )) && (( CAPACITY <= 30 )) && [[ "$LAST" != "low" ]]; then
        notify-send -u normal "Battery Low" "${CAPACITY}% remaining"
        echo "low" > "$STATE_FILE"
    elif (( CAPACITY > 30 )); then
        echo "" > "$STATE_FILE"
    fi
else
    echo "" > "$STATE_FILE"
fi
