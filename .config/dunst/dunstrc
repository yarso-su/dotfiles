[global]
    # Posición (top-right, top-left, bottom-right, bottom-left, top-center, bottom-center)
    origin = bottom-right
    offset = 10x10
    
    # Tamaño
    width = 300
    height = 100
    
    # Transparencia (0-100)
    transparency = 10
    
    # Bordes
    frame_width = 0
    frame_color = "#888888"
    separator_color = frame
    
    # Padding
    padding = 12
    horizontal_padding = 8
    
    # Fuente
    font = UbuntuNerd Font Mono 10
    
    # Formato del texto
    format = "<b>%s</b>\n%b"
    
    # Alineación (left, center, right)
    alignment = left
    
    # Tiempo en pantalla (segundos, 0 = infinito)
    timeout = 3
    
    # Ignorar nuevline
    ignore_newline = no
    
    # Mostrar cuántas notificaciones están ocultas
    indicate_hidden = yes
    
    # Iconos
    icon_position = left
    max_icon_size = 48
    
    # Comportamiento
    sticky_history = yes
    history_length = 1
    
    # Mouse
    mouse_left_click = close_current
    mouse_middle_click = do_action
    mouse_right_click = close_all

[urgency_low]
    background = "#222222"
    foreground = "#888888"
    timeout = 3

[urgency_normal]
    background = "#1c1c1c"
    foreground = "#dddddd"
    timeout = 5

[urgency_critical]
    background = "#900000"
    foreground = "#ffffff"
    frame_color = "#ff0000"
    timeout = 0
