general {
  colors = true
  interval = 5
}


battery all {
 last_full_capacity = true
 format_percentage = "%.0f%s"
 format = "Fairy Dust: %percentage"
 threshold_type = "percentage"
 low_threshold = 15
}
order += "battery all"


memory {
  format = "%used"
  threshold_degraded = "10%"
  format_degraded = "<span color='#FF0000'>%free</span>"
}
order += "memory"


tztime date {
  format = "%d-%m-%Y"
}
order += "tztime date"


tztime time {
  format = "%H:%M"
}
order += "tztime time"


wireless _first_ {
  format_up = "%essid"
  format_down = ""
}
order += "wireless _first_"
